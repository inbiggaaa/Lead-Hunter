# LeadHunter — environment variables
# Скопируй этот файл в .env и заполни значениями

# ── Telegram ──
BOT_TOKEN=123456:ABC-DEF1234ghijk
OWNER_TELEGRAM_ID=123456789

# ── Userbot (MTProto) — аккаунт 1 ──
# Получить на https://my.telegram.org/apps
USERBOT_API_ID=123456
USERBOT_API_HASH=abcdef1234567890abcdef1234567890
USERBOT_PHONE=+7XXXXXXXXXX  # опционально, для авто-ввода

# ── Userbot аккаунт 2 (опционально) ──
# Для второго телефона — зарегистрировать отдельное приложение на my.telegram.org
USERBOT_2_API_ID=654321
USERBOT_2_API_HASH=fedcba9876543210fedcba9876543210
USERBOT_2_PHONE=+7YYYYYYYYYY

# ── База данных ──
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=leadhunter
POSTGRES_PASSWORD=changeme_use_strong_password
POSTGRES_DB=leadhunter

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Админ-панель ──
ADMIN_PASSWORD=changeme_use_strong_password
ADMIN_SECRET=  # сгенерировать: openssl rand -hex 32
# Если не задан — WARNING в логах (сессии небезопасны)
ADMIN_PUBLIC_PORT=17421  # внешний порт для доступа к админке

# ── Платежи: Telegram Stars ──
# Работает из коробки с BOT_TOKEN

# ── Платежи: CryptoBot ──
CRYPTOBOT_API_TOKEN=  # опционально, из @CryptoBot
CRYPTOBOT_TESTNET=false

# ── LLM-валидация (DeepSeek) ──
DEEPSEEK_API_KEY=  # из platform.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Мониторинг ──
SENTRY_DSN=  # опционально, из sentry.io

# ── Лимиты (менять без правки кода) ──
MAX_SEGMENTS_FREE=1
MAX_SEGMENTS_PRO=3
MAX_CHANNELS_FREE=1
MAX_CHANNELS_PRO=15
MAX_KEYWORDS_FREE=1
MAX_KEYWORDS_PRO=50
NOTIFICATIONS_PER_DAY_FREE=50
NOTIFICATIONS_PER_DAY_PRO=150
TRIAL_DAYS=5
REFERRAL_TRIAL_BONUS=3
REFERRAL_BONUS_DAYS=7
MAX_REFERRALS_PER_MONTH=10
HEARTBEAT_INTERVAL_MINUTES=15
SENDER_THROTTLE_PER_SECOND=25
DAILY_REPORT_HOUR=19
BUSINESS_HIDDEN_CAP_CHANNELS=60
BUSINESS_HIDDEN_CAP_KEYWORDS=60
BUSINESS_HIDDEN_CAP_SEGMENTS=60

# ── Цены тарифов ──
PRICE_PRO_MONTHLY_USD=5
PRICE_BUSINESS_MONTHLY_USD=15

# Telegram Stars conversion (XTR per 1 USD). Actual rate varies ~80-120 XTR/USD.
STARS_PER_USD=100

# Session backup
SESSION_BACKUP_PASSPHRASE=

# S3-compatible storage for offsite backup (optional, NOT YET TESTED)
# Replace curl placeholder with awscli or b2 CLI when bucket is ready
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Discovery v3 ──
DISCOVERY_ENABLED=false
# DISCOVERY_API_ID=          # reuse userbot_api_id if not set
# DISCOVERY_API_HASH=        # reuse userbot_api_hash if not set
# DISCOVERY_PHONE=           # separate SIM for account #3
# DISCOVERY_SESSION_NAME=discovery
# DISCOVERY_ACCOUNT_ID=3     # 3 = dedicated, other = manual/test mode
# DISCOVERY_DAILY_LIMIT=500  # max SearchRequests per day (dedicated mode)
# DISCOVERY_MANUAL_DAILY_LIMIT=100  # max in manual/test mode
